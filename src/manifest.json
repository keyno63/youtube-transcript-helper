{
  "manifest_version": 3,
  "name": "YouTube Transcript Helper",
  "version": "1.0.0",
  "description": "Copy and save YouTube transcripts (manual panel open required).",
  "permissions": [
    "contextMenus",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
